@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-5 text-center">
    <h1 class="display-4 fw-bold text-primary">Project Approval System (PAS)</h1>
    <p class="lead mb-5">A secure, blind-matching platform for Undergraduate Research Proposals.</p>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>Students</h3>
                    <p>Submit your technical project proposals anonymously.</p>
                    <a asp-controller="Proposal" asp-action="Create" class="btn btn-primary w-100">Submit Proposal</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>Supervisors</h3>
                    <p>Review technical stacks and express interest blindly.</p>
                    <a asp-controller="Supervisor" asp-action="Dashboard" class="btn btn-success w-100">View Proposals</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h3>Module Leader</h3>
                    <p>Oversee the allocation process and manage categories.</p>
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-dark w-100">Admin Dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>