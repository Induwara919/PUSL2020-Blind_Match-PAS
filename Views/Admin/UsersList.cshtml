@using Microsoft.AspNetCore.Identity
@inject UserManager<PUSL2020_Blind_Match_PAS.Models.ApplicationUser> UserManager
@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ApplicationUser>
@{
    ViewData["Title"] = "User Management";
}

<style>
    :root { --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    body { background-color: #f8f9fa; }
    .modern-card { background: rgba(255, 255, 255, 0.9); border: none; border-radius: 15px; backdrop-filter: blur(10px); }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark"><i class="fas fa-users-cog me-3 text-primary"></i>Manage User Accounts</h2>
            <p class="text-muted mb-0">Manage Student, Supervisor and Admin Accounts</p>
        </div>
        <a asp-action="RegisterUser" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-user-plus me-2"></i>Add User
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center">
            <i class="fas fa-exclamation-triangle me-3 fs-4"></i>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }

    <div class="card modern-card shadow-sm p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr class="text-muted small text-uppercase">
                        <th>Full Name</th>
                        <th>Email / Username</th>
                        <th>Student ID</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = await UserManager.GetRolesAsync(user);
                        var roleName = roles.FirstOrDefault() ?? "No Role";

                        string badgeClass = roleName switch
                        {
                            "Admin" => "bg-danger text-white",
                            "Supervisor" => "bg-primary text-white",
                            "Student" => "bg-success text-white",
                            _ => "bg-light text-secondary"
                        };
                        <tr>
                            <td>
                                <div class="fw-bold text-dark">@user.FullName</div>
                                <span class="badge @badgeClass rounded-pill fw-normal">@roleName</span>
                            </td>
                            <td>@user.Email</td>
                            <td class="font-monospace">@(string.IsNullOrEmpty(user.StudentId) ? "N/A" : user.StudentId)</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="fas fa-edit me-1"></i>Edit
                                    </a>
                                    <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Are you sure? This cannot be undone.');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                            <i class="fas fa-trash-alt me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>