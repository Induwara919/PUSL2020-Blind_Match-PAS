@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Admin Oversight";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Module Leader Dashboard</h2>
        <span class="badge bg-dark">Total Proposals: @Model.Count()</span>
    </div>

    <table class="table table-hover border">
        <thead class="table-light">
            <tr>
                <th>Project Title</th>
                <th>Research Area</th>
                <th>Status</th>
                <th>Student</th>
                <th>Supervisor</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td><strong>@item.Title</strong></td>
                    <td>@item.ResearchArea</td>
                    <td>
                        <span class="badge @(item.Status == "Matched" ? "bg-success" : "bg-warning text-dark")">
                            @item.Status
                        </span>
                    </td>
                    <td>@(item.IsIdentityRevealed ? item.StudentName : "Hidden (Blind)")</td>
                    <td>@(item.SupervisorName ?? "Unassigned")</td>
                    <td>
                        <form asp-action="ResetStatus" asp-route-id="@item.Id" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Reset</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
