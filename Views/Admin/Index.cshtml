@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ProjectProposal>

<div class="container mt-4">
    <h2>Admin Oversight Dashboard</h2>
    <table class="table table-striped shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Project Title</th>
                <th>Student</th>
                <th>Supervisor</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.StudentName</td>
                    <td>@(item.SupervisorName ?? "Not Assigned")</td>
                    <td><span class="badge bg-info">@item.Status</span></td>
                    <td>
                        <button class="btn btn-sm btn-danger" onclick="confirmReset(@item.Id)">Reset Match</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
