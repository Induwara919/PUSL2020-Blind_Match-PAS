@model IEnumerable<string>

@{
    ViewData["Title"] = "Manage Research Areas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Research Area Management</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Oversight</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            Current Active Tags
        </div>
        <ul class="list-group list-group-flush">
            @foreach (var tag in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @tag
                    <span class="badge bg-success rounded-pill">Active</span>
                </li>
            }
        </ul>
    </div>

    <div class="alert alert-info mt-4">
        <strong>Note:</strong> These tags populate the dropdown menus for Students and Supervisors to ensure data consistency.
    </div>
</div>
