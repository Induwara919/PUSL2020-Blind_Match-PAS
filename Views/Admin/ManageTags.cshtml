@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.Tag>

<div class="container mt-4">
    <h2>Manage Research Areas</h2>
    
    <form asp-action="AddTag" method="post" class="row g-3 mb-4">
        <div class="col-auto">
            <input type="text" name="tagName" class="form-control" placeholder="New Area (e.g. AI)" required>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Add Tag</button>
        </div>
    </form>

    <table class="table table-hover border shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Research Area Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tag in Model)
            {
                <tr>
                    <td>@tag.Id</td>
                    <td>@tag.Name</td>
                </tr>
            }
        </tbody>
    </table>
</div>
