@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "My Project Status";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Submitted Proposals</h2>
        <a asp-action="Create" class="btn btn-success">Submit New Proposal</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title text-primary">@item.Title</h5>
                            <span class="badge @(item.Status == "Matched" ? "bg-success" : "bg-warning text-dark")">
                                @item.Status
                            </span>
                        </div>
                        <p class="text-muted small">Area: @item.ResearchArea</p>
                        <hr />
                        
                        @if (item.IsIdentityRevealed)
                        {
                            <div class="alert alert-success">
                                <strong>Match Confirmed!</strong><br />
                                <strong>Supervisor:</strong> @item.SupervisorName<br />
                                <strong>Contact:</strong> @item.SupervisorContact
                            </div>
                        }
                        else
                        {
                            <p class="card-text text-secondary italic">Waiting for a supervisor to express interest. Your identity is currently hidden.</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>