@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ProjectProposal>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Submitted Proposals</h2>
        <a asp-action="Create" class="btn btn-success">Submit New Proposal</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">@item.Title</h5>
                            <span class="badge @(item.Status == "Matched" ? "bg-success" : "bg-warning text-dark")">
                                @item.Status
                            </span>
                        </div>
                        <p class="text-muted small">Area: @item.ResearchArea</p>
                        <hr />
                        
                        @if (item.IsIdentityRevealed)
                        {
                            <div class="alert alert-success">
                                <strong>Match Confirmed!</strong><br />
                                <strong>Supervisor:</strong> @item.SupervisorName
                            </div>
                        }
                        else
                        {
                            <p class="card-text text-secondary small italic mb-3">Your identity is currently hidden from supervisors.</p>
                            
                            <div class="d-flex">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-2">Edit</a>
                                <form asp-action="Withdraw" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to withdraw this proposal?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Withdraw</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
