@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Supervisor Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Anonymous Project Proposals</h2>

    <form asp-action="Dashboard" method="get" class="mb-4">
        <div class="input-group" style="max-width: 400px;">
            <select name="searchArea" class="form-control">
                <option value="">All Research Areas</option>
                <option value="Artificial Intelligence">Artificial Intelligence</option>
                <option value="Web Development">Web Development</option>
                <option value="Cybersecurity">Cybersecurity</option>
                <option value="Cloud Computing">Cloud Computing</option>
            </select>
            <button type="submit" class="btn btn-secondary">Filter</button>
        </div>
    </form>

    <div class="row">
        @foreach (var item in Model) {
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@item.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Area: @item.ResearchArea</h6>
                        <p class="card-text"><strong>Tech Stack:</strong> @item.TechnicalStack</p>
                        <p class="card-text">@item.Abstract</p>
                        <hr />
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-info text-dark">Status: @item.Status</span>
                            <form asp-controller="Match" asp-action="Confirm" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-success">Express Interest</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
