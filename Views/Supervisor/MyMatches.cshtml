@model IEnumerable<PUSL2020_Blind_Match_PAS.Models.ProjectProposal>
@{
    ViewData["Title"] = "My Confirmed Matches";
}

<style>
    :root {
        --success-gradient: linear-gradient(135deg, #00b09b 0%, #96c93d 100%);
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    body {
        background-color: #f8f9fa;
    }

    .match-header {
        background: var(--primary-gradient);
        border-radius: 20px;
        padding: 2rem;
        color: white;
        margin-bottom: 2.5rem;
        box-shadow: 0 10px 25px rgba(118, 75, 162, 0.2);
    }

    .match-card {
        background: white;
        border: none;
        border-radius: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
    }

        .match-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.08) !important;
        }

    .reveal-banner {
        background: var(--success-gradient);
        color: white;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 8px 0;
        text-align: center;
        width: 100%;
    }

    .student-info-box {
        background-color: #f0fdf4;
        border: 1px dashed #bbf7d0;
        border-radius: 15px;
        padding: 1.25rem;
    }

    .btn-back {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: none;
        border-radius: 10px;
        backdrop-filter: blur(5px);
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background: rgba(255, 255, 255, 0.3);
            color: white;
        }

    .abstract-text {
        color: #64748b;
        font-size: 0.9rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="match-header d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <a asp-action="Dashboard" class="btn btn-back me-3 py-2 px-3">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0">Confirmed Matches</h2>
                <p class="mb-0 opacity-75">Students you are officially supervising</p>
            </div>
        </div>
        <div class="d-none d-md-block">
            <i class="fas fa-handshake fa-3x opacity-25"></i>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 py-5 text-center">
            <div class="card-body">
                <div class="mb-3">
                    <i class="fas fa-comment-slash fa-3x text-muted opacity-50"></i>
                </div>
                <h4 class="text-secondary">No matches found yet.</h4>
                <p class="text-muted">Once you express interest in a proposal and it's confirmed, it will appear here.</p>
                <a asp-action="Dashboard" class="btn btn-primary rounded-pill px-4 mt-2">Browse Proposals</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-6">
                    <div class="card match-card shadow-sm h-100">
                        <div class="reveal-banner">
                            <i class="fas fa-lock-open me-2"></i> Identity Revealed
                        </div>

                        <div class="card-body p-4">
                            <h5 class="fw-bold text-dark mb-1">@item.Title</h5>
                            <span class="badge bg-light text-primary mb-4">@item.ResearchArea</span>

                            <div class="student-info-box mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-success rounded-circle p-2 me-2 text-white" style="width:32px; height:32px; display:flex; align-items:center; justify-content:center;">
                                        <i class="fas fa-user-graduate small"></i>
                                    </div>
                                    <span class="small fw-bold text-success uppercase">Assigned Student</span>
                                </div>
                                <h6 class="mb-1 fw-bold text-dark">@item.StudentName</h6>
                                <p class="mb-0 text-muted small"><i class="fas fa-id-card-alt me-1"></i> Student ID: @item.StudentId</p>
                            </div>

                            <div class="pt-2">
                                <label class="small fw-bold text-muted text-uppercase mb-2">Abstract Overview</label>
                                <p class="abstract-text mb-0">@item.Abstract</p>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>
